{
    "name": "aurora/testing",
    "description": "Testing utilities for Aurora CMS — base test case, entity factories, and helper traits.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\Testing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\Testing\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
