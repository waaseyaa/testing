{
    "name": "waaseyaa/testing",
    "description": "Testing utilities for Waaseyaa \u2014 base test case, entity factories, and helper traits.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        }
    ],
    "require": {
        "php": ">=8.4",
        "phpunit/phpunit": "^10.5",
        "symfony/event-dispatcher": "^7.0",
        "waaseyaa/entity": "^0.1.0-alpha.150"
    },
    "suggest": {
        "fakerphp/faker": "Optional realistic strings and emails for EntityTypeFixtureValues (framework#1186)."
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Testing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Testing\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
